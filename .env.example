# === Repositorios de codigo (OBRIGATORIO - ajustar para sua maquina) ===
# Copie este arquivo como .env e ajuste os caminhos para seu ambiente local.
# O .env ja esta no .gitignore — cada dev cria o seu.

# PL/SQL, PowerBuilder, Java, DDLs (OBRIGATORIO)
TAXONE_DW_REPO=C:/Repositorios/taxone_dw

# XMLs esperados do SuiteAutomation - branch rc (OBRIGATORIO)
QA_REPO=C:/Repositorios/taxone_automacao_qa

# Testes E2E Playwright (OPCIONAL)
PLAYWRIGHT_REPO=

# Frontend Angular 11 - monorepo (OPCIONAL)
TAXONE_FRONTEND_REPO=C:/Repositorios/taxsami_taxone_frontend

# === Azure DevOps (OBRIGATORIO para agentes de triagem/planning/auto-fix) ===
# Gerar em: https://dev.azure.com/tr-ggo/_usersSettings/tokens
ADO_PAT=

# === Zendesk (OPCIONAL - para agentes N3 triage e PM) ===
# Usado por scripts/zendesk_client.py para enriquecimento de Work Items
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
# Se atras de proxy corporativo com SSL issues, descomentar:
# ZENDESK_SKIP_SSL=1
